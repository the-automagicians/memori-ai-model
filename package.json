{
  "name": "n8n-nodes-memori",
  "version": "0.2.9",
  "description": "n8n community node exposing a Memori-aware Chat Model sub-node for AI Agent. Injects memori_attribution (entity_id, process_id, session_id) into every chat completion request so a self-hosted Memori proxy can partition knowledge per user/session.",
  "license": "MIT",
  "homepage": "https://github.com/the-automagicians/memori-ai-model#readme",
  "bugs": {
    "url": "https://github.com/the-automagicians/memori-ai-model/issues"
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "memori",
    "ai-agent",
    "langchain"
  ],
  "author": { "name": "Imago Platform", "email": "admin@imagoplatform.ai" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-automagicians/memori-ai-model.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": false,
    "credentials": ["dist/credentials/MemoriApi.credentials.js"],
    "nodes": ["dist/nodes/LmChatMemori/LmChatMemori.node.js"]
  },
  "dependencies": { "@langchain/openai": "^0.3.0" },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "eslint": "9.39.4",
    "prettier": "3.8.3",
    "release-it": "19.2.4",
    "typescript": "5.9.3"
  },
  "peerDependencies": { "n8n-workflow": "*" }
}
